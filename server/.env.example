PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (replace with your own)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bookstore?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRE=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Admin seed credentials (used only by seed script)
ADMIN_EMAIL=admin@bookstore.com
ADMIN_PASSWORD=Admin@12345
